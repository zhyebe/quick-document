{
  "name": "quick-document",
  "version": "0.1.4",
  "description": "Cross-platform AI desktop assistant for Word, Excel, and PowerPoint documents.",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Quick Document",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:ci": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:ci": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.quickdocument.desktop",
    "productName": "Quick Document",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Quick Document 使用麦克风把语音输入转成文字并填入输入框。"
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
